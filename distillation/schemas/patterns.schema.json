{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Section writing moves",
  "type": "object",
  "required": ["section", "moves", "variant_notes"],
  "properties": {
    "section": {"type": "string"},
    "variant_notes": {"type": "string"},
    "moves": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decision", "scope", "evidence_ids", "failure_mode", "check"],
        "properties": {
          "id": {"type": "string"},
          "decision": {"type": "string"},
          "scope": {"enum": ["invariant", "family", "profile"]},
          "evidence_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "failure_mode": {"type": "string"},
          "check": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
