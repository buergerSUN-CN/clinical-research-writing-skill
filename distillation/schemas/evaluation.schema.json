{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Leave-one-out clinical writing evaluation",
  "type": "object",
  "required": ["paper_id", "family", "invented_facts", "numeric_fidelity", "clinical_authenticity", "template_tells", "verdict"],
  "properties": {
    "paper_id": {"type": "string"},
    "family": {"type": "string"},
    "invented_facts": {"type": "array", "items": {"type": "string"}},
    "numeric_fidelity": {"type": "number", "minimum": 0, "maximum": 1},
    "clinical_authenticity": {"type": "integer", "minimum": 1, "maximum": 5},
    "template_tells": {"type": "array", "items": {"type": "string"}},
    "verdict": {"enum": ["pass", "fail", "revise"]}
  },
  "additionalProperties": true
}
